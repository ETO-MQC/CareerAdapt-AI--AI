AI_PROVIDER=openai-compatible
AI_API_KEY=replace-with-your-api-key
AI_BASE_URL=https://token-plan-cn.xiaomimimo.com/anthropic
AI_MODEL=mimo-v2.5-pro

# Optional isolated local OCR sidecar. Keep model files and tokens outside Git.
PADDLEOCR_VL_ENDPOINT=http://127.0.0.1:8765
PADDLEOCR_VL_TOKEN=replace-with-a-local-random-token
PADDLEOCR_VL_MODEL_DIR=C:\path\to\PaddleOCR-VL-1.6
PADDLEOCR_VL_DEVICE=gpu
