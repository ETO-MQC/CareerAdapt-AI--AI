{
  "name": "careeradapt-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:ai:real": "vitest run --config vitest.ai-real.config.ts",
    "test:c1:eval": "vitest run --config vitest.c1-eval.config.ts",
    "test:c2:eval": "vitest run --config vitest.c2-eval.config.ts",
    "test:e2e": "playwright test",
    "verify": "pnpm typecheck && pnpm lint && pnpm test && pnpm build"
  },
  "dependencies": {
    "@tiptap/extension-placeholder": "^3.27.3",
    "@tiptap/pm": "^3.27.3",
    "@tiptap/react": "^3.27.3",
    "@tiptap/starter-kit": "^3.27.3",
    "dexie": "^4.4.4",
    "lucide-react": "^1.25.0",
    "nanoid": "^5.1.16",
    "next": "^16.2.9",
    "pdfjs-dist": "5.4.296",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "pdf-lib": "^1.17.1",
    "postcss": "^8.5.16",
    "tailwindcss": "3.4.17",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
